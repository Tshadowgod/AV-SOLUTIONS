# Copia este archivo como .env.local y completa los valores reales

# Cadena de conexión de Neon PostgreSQL (https://neon.tech)
DATABASE_URL="postgresql://usuario:contraseña@host/neondb?sslmode=require"

# Contraseña del panel de administración
ADMIN_PASSWORD="elige-una-contraseña-segura"

# Secreto aleatorio para firmar sesiones (32+ caracteres)
AUTH_SECRET="genera-una-cadena-aleatoria-larga"

# Aviso por WhatsApp al recibir una cotización (CallMeBot, opcional)
WHATSAPP_NOTIFY_PHONE="59165073163"
CALLMEBOT_APIKEY=""
